<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CameraMapper">

    <resultMap type="Camera" id="CameraResult">
        <result property="id"    column="id"    />
        <result property="platformNo"    column="platform_no"    />
        <result property="name"    column="name"    />
        <result property="ip"    column="ip"    />
        <result property="floor"    column="floor"    />
        <result property="status"    column="status"    />
        <result property="xAxis"    column="x_axis"    />
        <result property="yAxis"    column="y_axis"    />
        <result property="remark"    column="remark"    />
        <result property="latitude"    column="latitude"    />
        <result property="longitude"    column="longitude"    />
        <result property="streamURL"    column="stream_url"    />
        <result property="userName"    column="user_name"    />
        <result property="userPwd"    column="user_pwd"    />
        <result property="cameraId"    column="camera_id"    />
        <result property="cameraGroupId"    column="camera_group_id"    />
    </resultMap>

    <sql id="selectCameraVo">
        select id, platform_no, name, ip, floor, status, x_axis, y_axis, remark, latitude, longitude, stream_url, user_name, user_pwd, camera_id, camera_group_id
        from camera
    </sql>

    <select id="selectCameraList" parameterType="Camera" resultMap="CameraResult">
        <include refid="selectCameraVo"/>
        <where>  
            <if test="platformNo != null and platformNo != ''">
                AND platform_no = #{platformNo}
            </if>
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="ip != null and ip != ''">
                AND ip like concat('%', #{ip}, '%')
            </if>
            <if test="floor != null and floor != ''">
                AND floor = #{floor}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by floor, name
    </select>

    <select id="selectCameraById" parameterType="Long" resultMap="CameraResult">
        <include refid="selectCameraVo"/>
        where id = #{id}
    </select>

    <select id="checkIpUnique" parameterType="String" resultMap="CameraResult">
        select id, ip from camera where ip = #{ip}
        <if test="platformNo != null and platformNo != ''">
            AND platform_no = #{platformNo}
        </if>
        limit 1
    </select>

    <select id="selectCamerasByFloor" parameterType="String" resultMap="CameraResult">
        <include refid="selectCameraVo"/>
        where floor = #{floor}
        order by name
    </select>

    <insert id="insertCamera" parameterType="Camera" useGeneratedKeys="true" keyProperty="id">
        insert into camera
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="ip != null and ip != ''">ip,</if>
            <if test="floor != null">floor,</if>
            <if test="status != null">status,</if>
            <if test="xAxis != null">x_axis,</if>
            <if test="yAxis != null">y_axis,</if>
            <if test="remark != null">remark,</if>
            <if test="latitude != null">latitude,</if>
            <if test="longitude != null">longitude,</if>
            <if test="streamURL != null">stream_url,</if>
            <if test="userName != null">user_name,</if>
            <if test="userPwd != null">user_pwd,</if>
            <if test="cameraId != null">camera_id,</if>
            <if test="cameraGroupId != null">camera_group_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">#{platformNo},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="ip != null and ip != ''">#{ip},</if>
            <if test="floor != null">#{floor},</if>
            <if test="status != null">#{status},</if>
            <if test="xAxis != null">#{xAxis},</if>
            <if test="yAxis != null">#{yAxis},</if>

            <if test="remark != null">#{remark},</if>
            <if test="latitude != null">#{latitude},</if>
            <if test="longitude != null">#{longitude},</if>
            <if test="streamURL != null">#{streamURL},</if>
            <if test="userName != null">#{userName},</if>
            <if test="userPwd != null">#{userPwd},</if>
            <if test="cameraId != null">#{cameraId},</if>
            <if test="cameraGroupId != null">#{cameraGroupId},</if>
        </trim>
    </insert>

    <update id="updateCamera" parameterType="Camera">
        update camera
        <trim prefix="SET" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no = #{platformNo},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="ip != null and ip != ''">ip = #{ip},</if>
            <if test="floor != null">floor = #{floor},</if>
            <if test="status != null">status = #{status},</if>
            <if test="xAxis != null">x_axis = #{xAxis},</if>
            <if test="yAxis != null">y_axis = #{yAxis},</if>

            <if test="remark != null">remark = #{remark},</if>
            <if test="latitude != null">latitude = #{latitude},</if>
            <if test="longitude != null">longitude = #{longitude},</if>
            <if test="streamURL != null">stream_url = #{streamURL},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="userPwd != null">user_pwd = #{userPwd},</if>
            <if test="cameraId != null">camera_id = #{cameraId},</if>
            <if test="cameraGroupId != null">camera_group_id = #{cameraGroupId},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCameraById" parameterType="Long">
        delete from camera where id = #{id}
    </delete>

    <delete id="deleteCameraByIds" parameterType="String">
        delete from camera where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 统计摄像头总数 -->
    <select id="countCameraTotal" resultType="int">
        select count(*) from camera
        <where>
            <if test="platformNo != null and platformNo != ''">
                platform_no = #{platformNo}
            </if>
        </where>
    </select>

    <!-- 统计开启的摄像头数 -->
    <select id="countCameraOnline" resultType="int">
        select count(*) from camera 
        <where>
            status = 'online'
            <if test="platformNo != null and platformNo != ''">
                and platform_no = #{platformNo}
            </if>
        </where>
    </select>

    <!-- 根据摄像机ID查询摄像机 -->
    <select id="selectCameraByCameraId" parameterType="String" resultMap="CameraResult">
        <include refid="selectCameraVo"/>
        where camera_id = #{cameraId}
        limit 1
    </select>

</mapper>
