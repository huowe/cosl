<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CameraMapper">

    <resultMap type="Camera" id="CameraResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="ip"    column="ip"    />
        <result property="floor"    column="floor"    />
        <result property="status"    column="status"    />
        <result property="xAxis"    column="x_axis"    />
        <result property="yAxis"    column="y_axis"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectCameraVo">
        select id, name, ip, floor, status, x_axis, y_axis, remark
        from camera
    </sql>

    <select id="selectCameraList" parameterType="Camera" resultMap="CameraResult">
        <include refid="selectCameraVo"/>
        <where>  
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="ip != null and ip != ''">
                AND ip like concat('%', #{ip}, '%')
            </if>
            <if test="floor != null and floor != ''">
                AND floor = #{floor}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by floor, name
    </select>

    <select id="selectCameraById" parameterType="Long" resultMap="CameraResult">
        <include refid="selectCameraVo"/>
        where id = #{id}
    </select>

    <select id="checkIpUnique" parameterType="String" resultMap="CameraResult">
        select id, ip from camera where ip = #{ip} limit 1
    </select>

    <select id="selectCamerasByFloor" parameterType="String" resultMap="CameraResult">
        <include refid="selectCameraVo"/>
        where floor = #{floor}
        order by name
    </select>

    <insert id="insertCamera" parameterType="Camera" useGeneratedKeys="true" keyProperty="id">
        insert into camera
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="ip != null and ip != ''">ip,</if>
            <if test="floor != null">floor,</if>
            <if test="status != null">status,</if>
            <if test="xAxis != null">x_axis,</if>
            <if test="yAxis != null">y_axis,</if>

            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="ip != null and ip != ''">#{ip},</if>
            <if test="floor != null">#{floor},</if>
            <if test="status != null">#{status},</if>
            <if test="xAxis != null">#{xAxis},</if>
            <if test="yAxis != null">#{yAxis},</if>

            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateCamera" parameterType="Camera">
        update camera
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="ip != null and ip != ''">ip = #{ip},</if>
            <if test="floor != null">floor = #{floor},</if>
            <if test="status != null">status = #{status},</if>
            <if test="xAxis != null">x_axis = #{xAxis},</if>
            <if test="yAxis != null">y_axis = #{yAxis},</if>

            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCameraById" parameterType="Long">
        delete from camera where id = #{id}
    </delete>

    <delete id="deleteCameraByIds" parameterType="String">
        delete from camera where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 统计摄像头总数 -->
    <select id="countCameraTotal" resultType="int">
        select count(*) from camera
    </select>

    <!-- 统计开启的摄像头数 -->
    <select id="countCameraOnline" resultType="int">
        select count(*) from camera where status = 'online'
    </select>

</mapper>
