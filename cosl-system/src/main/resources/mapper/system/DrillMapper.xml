<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.DrillMapper">
    
    <resultMap type="Drill" id="DrillResult">
        <id     property="id"           column="id"          />
        <result property="platformNo"   column="platform_no" />
        <result property="name"         column="name"        />
        <result property="startTime"    column="start_time"  />
        <result property="endTime"      column="end_time"    />
        <result property="expectedCount" column="expected_count" />
        <result property="actualCount"  column="actual_count" />
        <result property="status"       column="status"      />
        <result property="createTime"   column="create_time" />

    </resultMap>
    
    <sql id="selectDrillVo">
        select id, platform_no, name, start_time, end_time, expected_count, actual_count, status, create_time
		from drill
    </sql>
    
    <!-- 查询条件 -->
	<sql id="sqlwhereSearch">
		<where>
            <if test="platformNo != null and platformNo != ''">
                and platform_no = #{platformNo}
            </if>
            <if test="id !=null">
                and id = #{id}
            </if>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
				and date_format(create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
			</if>
			<if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
				and date_format(create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
			</if>
		</where>
	</sql>
    
    <select id="selectDrillById" parameterType="Long" resultMap="DrillResult">
        <include refid="selectDrillVo"/>
        where id = #{id}
    </select>
    
    <select id="selectDrillList" parameterType="Drill" resultMap="DrillResult">
        <include refid="selectDrillVo"/>
        <include refid="sqlwhereSearch"/>
    </select>
    
    <insert id="insertDrill" parameterType="Drill" useGeneratedKeys="true" keyProperty="id">
        insert into drill
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="expectedCount != null">expected_count,</if>
            <if test="actualCount != null">actual_count,</if>
            <if test="status != null and status != ''">status,</if>

 			create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">#{platformNo},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="expectedCount != null">#{expectedCount},</if>
            <if test="actualCount != null">#{actualCount},</if>
            <if test="status != null and status != ''">#{status},</if>

 			sysdate(),
        </trim>
    </insert>
	 
    <update id="updateDrill" parameterType="Drill">
        update drill
        <trim prefix="SET" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no = #{platformNo},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="expectedCount != null">expected_count = #{expectedCount},</if>
            <if test="actualCount != null">actual_count = #{actualCount},</if>
            <if test="status != null and status != ''">status = #{status}</if>
        </trim>
        where id = #{id}
    </update>
	
    <delete id="deleteDrillById" parameterType="Long">
        delete from drill where id = #{id}
    </delete>
	
    <delete id="deleteDrillByIds" parameterType="String">
        delete from drill where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="checkDrillPersonExist" parameterType="DrillPerson" resultType="DrillPerson">
        select id, drill_id, person_id
        from drill_person
        where drill_id = #{drillId} and person_id = #{personId}
    </select>
    <insert id="insertDrillPerson" parameterType="DrillPerson">
        insert into drill_person
        <trim prefix="(" suffix=")" suffixOverrides=",">
            drill_id,
            person_id,
            status,
            create_time,
            update_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{drillId},
            #{personId},
            #{status},
            sysdate(),
            sysdate(),
        </trim>
    </insert>
    <update id="updateDrillPerson" parameterType="DrillPerson">
        update drill_person
        <trim prefix="SET" suffixOverrides=",">
            <if test="drillId != null">drill_id = #{drillId},</if>
            <if test="personId != null">person_id = #{personId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = sysdate()</if>

        </trim>
        where id = #{id}
    </update>

    <!-- 统计本月演习次数 -->
    <select id="countDrillThisMonth" resultType="int">
        select count(*) from drill 
        <where>
            DATE_FORMAT(create_time, '%Y-%m') = DATE_FORMAT(CURDATE(), '%Y-%m')
            <if test="platformNo != null and platformNo != ''">
                and platform_no = #{platformNo}
            </if>
        </where>
    </select>

    <!-- 统计演习累计次数 -->
    <select id="countDrillTotal" resultType="int">
        select count(*) from drill
        <where>
            <if test="platformNo != null and platformNo != ''">
                platform_no = #{platformNo}
            </if>
        </where>
    </select>
    
</mapper>
