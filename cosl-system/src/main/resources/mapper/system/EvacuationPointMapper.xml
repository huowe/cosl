<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.EvacuationPointMapper">
    
    <resultMap type="EvacuationPoint" id="EvacuationPointResult">
        <result property="id"    column="id"    />
        <result property="platformNo"    column="platform_no"    />
        <result property="pointName"    column="point_name"    />
        <result property="floor"    column="floor"    />
        <result property="xAxis"    column="x_axis"    />
        <result property="yAxis"    column="y_axis"    />
        <result property="cameraId"    column="camera_id"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="deleted"    column="deleted"    />
        <!-- 关联查询救生艇列表 -->
        <collection property="lifeboats" ofType="LifeboatConfig" column="id" select="selectLifeboatsByEvacuationPointId" />
    </resultMap>

    <resultMap type="LifeboatConfig" id="LifeboatConfigResult">
        <id     property="id"                column="lifeboat_id"          />
        <result property="platformNo"        column="platform_no"          />
        <result property="boatNo"            column="boat_no"              />
        <result property="boatName"          column="boat_name"            />
        <result property="maxCapacity"       column="max_capacity"         />
        <result property="evacuationPointId" column="evacuation_point_id"  />
        <result property="status"            column="lifeboat_status"      />
        <result property="remark"            column="lifeboat_remark"      />
        <result property="deleted"           column="deleted"              />
        <!-- 关联查询简化人员信息 -->
        <collection property="personList" ofType="SimplePersonInfo" column="lifeboat_id" select="selectSimplePersonsByLifeboatId" />
    </resultMap>

    <sql id="selectEvacuationPointVo">
        select id, platform_no, point_name, floor, x_axis, y_axis, camera_id, remark, create_time, update_time, deleted from evacuation_point
    </sql>

    <select id="selectEvacuationPointList" parameterType="EvacuationPoint" resultMap="EvacuationPointResult">
        <include refid="selectEvacuationPointVo"/>
        <where>  
            deleted = 0
            <if test="platformNo != null and platformNo != ''"> and platform_no = #{platformNo}</if>
            <if test="pointName != null  and pointName != ''"> and point_name like concat('%', #{pointName}, '%')</if>
            <if test="floor != null  and floor != ''"> and floor = #{floor}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectEvacuationPointById" parameterType="Long" resultMap="EvacuationPointResult">
        <include refid="selectEvacuationPointVo"/>
        where id = #{id} and deleted = 0
    </select>
        
    <select id="checkPointNameUnique" parameterType="String" resultMap="EvacuationPointResult">
        <include refid="selectEvacuationPointVo"/>
        where point_name = #{pointName}
        <if test="platformNo != null and platformNo != ''">
            AND platform_no = #{platformNo}
        </if>
        and deleted = 0 limit 1
    </select>
    
    <insert id="insertEvacuationPoint" parameterType="EvacuationPoint" useGeneratedKeys="true" keyProperty="id">
        insert into evacuation_point
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no,</if>
            <if test="pointName != null and pointName != ''">point_name,</if>
            <if test="floor != null">floor,</if>
            <if test="xAxis != null">x_axis,</if>
            <if test="yAxis != null">y_axis,</if>
            <if test="cameraId != null and cameraId != ''">camera_id,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="deleted != null">deleted,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">#{platformNo},</if>
            <if test="pointName != null and pointName != ''">#{pointName},</if>
            <if test="floor != null">#{floor},</if>
            <if test="xAxis != null">#{xAxis},</if>
            <if test="yAxis != null">#{yAxis},</if>
            <if test="cameraId != null and cameraId != ''">#{cameraId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="deleted != null">#{deleted},</if>
         </trim>
    </insert>

    <update id="updateEvacuationPoint" parameterType="EvacuationPoint">
        update evacuation_point
        <trim prefix="SET" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no = #{platformNo},</if>
            <if test="pointName != null and pointName != ''">point_name = #{pointName},</if>
            <if test="floor != null">floor = #{floor},</if>
            <if test="xAxis != null">x_axis = #{xAxis},</if>
            <if test="yAxis != null">y_axis = #{yAxis},</if>
            <if test="cameraId != null and cameraId != ''">camera_id = #{cameraId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="deleted != null">deleted = #{deleted},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteEvacuationPointById" parameterType="Long">
        update evacuation_point set deleted = 1 where id = #{id}
    </delete>

    <delete id="deleteEvacuationPointByIds" parameterType="String">
        update evacuation_point set deleted = 1 where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 根据撤离点ID查询救生艇列表 -->
    <select id="selectLifeboatsByEvacuationPointId" parameterType="Long" resultMap="LifeboatConfigResult">
        select lc.id as lifeboat_id, lc.platform_no, lc.boat_no, lc.boat_name, 
               lc.max_capacity, lc.evacuation_point_id, lc.status as lifeboat_status,
               lc.remark as lifeboat_remark, lc.deleted
        from lifeboat_config lc
        where lc.evacuation_point_id = #{id} and lc.deleted = 0
        order by lc.boat_no
    </select>

    <!-- 根据救生艇ID查询简化人员信息 -->
    <select id="selectSimplePersonsByLifeboatId" parameterType="Long" resultType="SimplePersonInfo">
        select p.id, p.name, p.monitor_id as monitorId
        from person p

        where p.lifeboat_id = #{lifeboatId} and p.deleted = 0
        order by p.name
    </select>
    
</mapper>
