<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.FloorConfigMapper">
    
    <resultMap type="FloorConfig" id="FloorConfigResult">
        <result property="id"    column="id"    />
        <result property="platformNo"    column="platform_no"    />
        <result property="floorNo"    column="floor_no"    />
        <result property="floorName"    column="floor_name"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="deleted"    column="deleted"    />
    </resultMap>

    <sql id="selectFloorConfigVo">
        select id, platform_no, floor_no, floor_name, sort_order, status, remark, create_by, create_time, update_by, update_time, deleted from floor_config
    </sql>

    <select id="selectFloorConfigList" parameterType="FloorConfig" resultMap="FloorConfigResult">
        <include refid="selectFloorConfigVo"/>
        <where>  
            deleted = 0
            <if test="platformNo != null and platformNo != ''"> and platform_no = #{platformNo}</if>
            <if test="floorNo != null and floorNo != ''"> and floor_no = #{floorNo}</if>
            <if test="floorName != null and floorName != ''"> and floor_name like concat('%', #{floorName}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by sort_order asc, create_time desc
    </select>
    
    <select id="selectFloorConfigById" parameterType="Long" resultMap="FloorConfigResult">
        <include refid="selectFloorConfigVo"/>
        where id = #{id} and deleted = 0
    </select>
        
    <select id="checkFloorNoUnique" parameterType="String" resultMap="FloorConfigResult">
        <include refid="selectFloorConfigVo"/>
        where floor_no = #{floorNo} and platform_no = #{platformNo} and deleted = 0 limit 1
    </select>

    <select id="selectActiveFloorList" resultMap="FloorConfigResult">
        <include refid="selectFloorConfigVo"/>
        where status = 'ACTIVE' and deleted = 0
        order by sort_order asc
    </select>
    
    <insert id="insertFloorConfig" parameterType="FloorConfig" useGeneratedKeys="true" keyProperty="id">
        insert into floor_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no,</if>
            <if test="floorNo != null and floorNo != ''">floor_no,</if>
            <if test="floorName != null and floorName != ''">floor_name,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="deleted != null">deleted,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">#{platformNo},</if>
            <if test="floorNo != null and floorNo != ''">#{floorNo},</if>
            <if test="floorName != null and floorName != ''">#{floorName},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="deleted != null">#{deleted},</if>
         </trim>
    </insert>

    <update id="updateFloorConfig" parameterType="FloorConfig">
        update floor_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no = #{platformNo},</if>
            <if test="floorNo != null and floorNo != ''">floor_no = #{floorNo},</if>
            <if test="floorName != null and floorName != ''">floor_name = #{floorName},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="deleted != null">deleted = #{deleted},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteFloorConfigById" parameterType="Long">
        update floor_config set deleted = 1 where id = #{id}
    </delete>

    <delete id="deleteFloorConfigByIds" parameterType="String">
        update floor_config set deleted = 1 where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>
