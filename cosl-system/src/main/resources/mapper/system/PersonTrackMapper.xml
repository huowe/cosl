<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.PersonTrackMapper">

    <resultMap type="PersonTrack" id="PersonTrackResult">
        <result property="id"    column="id"    />
        <result property="platformNo"    column="platform_no"    />
        <result property="personId"    column="person_id"    />
        <result property="cameraId"    column="camera_id"    />
        <result property="captureTime"    column="capture_time"    />
        <result property="xAxis"    column="x_axis"    />
        <result property="yAxis"    column="y_axis"    />
    </resultMap>

    <sql id="selectPersonTrackVo">
        select id, platform_no, person_id, camera_id, capture_time, x_axis, y_axis
        from person_track
    </sql>

    <select id="selectPersonTrackList" parameterType="PersonTrack" resultMap="PersonTrackResult">
        <include refid="selectPersonTrackVo"/>
        <where>  
            <if test="platformNo != null and platformNo != ''">
                AND platform_no = #{platformNo}
            </if>
            <if test="personId != null">
                AND person_id = #{personId}
            </if>
            <if test="cameraId != null">
                AND camera_id = #{cameraId}
            </if>
            <if test="captureTime != null">
                AND capture_time = #{captureTime}
            </if>
        </where>
        group by person_id
        order by capture_time desc
    </select>

    <select id="selectPersonTrackById" parameterType="Long" resultMap="PersonTrackResult">
        <include refid="selectPersonTrackVo"/>
        where id = #{id}
    </select>

    <insert id="insertPersonTrack" parameterType="PersonTrack" useGeneratedKeys="true" keyProperty="id">
        insert into person_track
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no,</if>
            <if test="personId != null">person_id,</if>
            <if test="cameraId != null">camera_id,</if>
            <if test="captureTime != null">capture_time,</if>
            <if test="xAxis != null">x_axis,</if>
            <if test="yAxis != null">y_axis</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">#{platformNo},</if>
            <if test="personId != null">#{personId},</if>
            <if test="cameraId != null">#{cameraId},</if>
            <if test="captureTime != null">#{captureTime},</if>
            <if test="xAxis != null">#{xAxis},</if>
            <if test="yAxis != null">#{yAxis}</if>
        </trim>
    </insert>

    <update id="updatePersonTrack" parameterType="PersonTrack">
        update person_track
        <trim prefix="SET" suffixOverrides=",">
            <if test="platformNo != null and platformNo != ''">platform_no = #{platformNo},</if>
            <if test="personId != null">person_id = #{personId},</if>
            <if test="cameraId != null">camera_id = #{cameraId},</if>
            <if test="captureTime != null">capture_time = #{captureTime},</if>
            <if test="xAxis != null">x_axis = #{xAxis},</if>
            <if test="yAxis != null">y_axis = #{yAxis}</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePersonTrackById" parameterType="Long">
        delete from person_track where id = #{id}
    </delete>

    <delete id="deletePersonTrackByIds" parameterType="String">
        delete from person_track where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
