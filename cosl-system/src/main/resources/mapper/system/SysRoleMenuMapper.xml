<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysRoleMenuMapper">

	<resultMap type="SysRoleMenu" id="SysRoleMenuResult">
		<result property="roleId"     column="role_id"      />
		<result property="menuId"     column="menu_id"      />
		<result property="platformNo" column="platform_no"  />
	</resultMap>

	<delete id="deleteRoleMenuByRoleId" parameterType="Long">
		delete from sys_role_menu where role_id=#{roleId}
	</delete>
	
	<delete id="deleteRoleMenuByRoleIdWithPlatform">
		delete from sys_role_menu where role_id=#{roleId}  <if test="platformNo != null and platformNo != ''">
		AND platform_no = #{platformNo}
	</if>
	</delete>
	
	<select id="selectCountRoleMenuByMenuId" resultType="Integer">
	    select count(1) from sys_role_menu where menu_id=#{menuId}  
	</select>
	
	<select id="selectCountRoleMenuByMenuIdWithPlatform" resultType="Integer">
	    select count(1) from sys_role_menu where menu_id=#{menuId}  <if test="platformNo != null and platformNo != ''">
		AND platform_no = #{platformNo}
	</if>
	</select>
	
	<delete id="deleteRoleMenu" parameterType="Long">
 		delete from sys_role_menu where role_id in
 		<foreach collection="array" item="roleId" open="(" separator="," close=")">
 			#{roleId}
        </foreach> 
 	</delete>
	
	<delete id="deleteRoleMenuWithPlatform">
 		delete from sys_role_menu where role_id in
 		<foreach collection="ids" item="roleId" open="(" separator="," close=")">
 			#{roleId}
        </foreach>
		<if test="platformNo != null and platformNo != ''">
			AND platform_no = #{platformNo}
		</if>
 	</delete>
	
	<insert id="batchRoleMenu">
		insert into sys_role_menu(role_id, menu_id, platform_no) values
		<foreach item="item" index="index" collection="list" separator=",">
			(#{item.roleId},#{item.menuId},#{item.platformNo})
		</foreach>
	</insert>
	
</mapper> 